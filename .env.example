# =============================================================================
# Repertoire — P0.1 platform env mesh (CORE-UNIFORMITY-PLAN)
# =============================================================================
# Copy to .env and fill in values for local dev or Hermes/cron hosts.
# Contract SSOT: ~/dev/0x0/docs/0x0-platform-contract.md (P0.1)
#
# Today: .mcp.json and .xray/features.json still hardcode absolute paths/URLs.
# P0.4 will refactor those to read from this mesh.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform contract (cross-repo)
# -----------------------------------------------------------------------------

# Dynamo MCP base URL (Railway production).
# Derived endpoints (P0.4 SSOT):
#   - /governance          → xray inference_governance (see .xray/features.json)
#   - /call_connected_tool → groover engage workers (DYNAMO_MCP alias)
#
# Derived (set in shell or MCP env — do not commit endpoint_url in features.json):
#   GOVERNANCE_ENDPOINT=${DYNAMO_MCP_URL}/governance  → xray-governance MCP
#   DYNAMO_MCP=${DYNAMO_MCP_URL}/call_connected_tool → groover engage workers
DYNAMO_MCP_URL=https://mcp-production-80e2.up.railway.app

# GOVERNANCE_ENDPOINT=https://mcp-production-80e2.up.railway.app/governance

# 0xRay consumer project root — all xray MCP servers resolve config from here.
# Hardcoded today in .mcp.json for every xray-* server (replace with your checkout).
XRAY_ROOT=/path/to/repertoire

# Absolute path to this Repertoire package root.
# Groover deploy uses REPERTOIRE_ROOT for in-process consult + post-tick feedback + ingest.
# SKIP_REPERTOIRE_INGEST=1 — disable auto-ingest after each cron tick (A3.1).
# Default resolution: sibling ../repertoire, then node_modules/@0xray/repertoire.
REPERTOIRE_ROOT=/path/to/repertoire

# Moltbook is NOT a Repertoire dependency — optional field-actuation add-on per project.
# Groover activates it in deploy/moltbook-*.ts with its own MOLTBOOK_API_KEY on the cron host.
# Repertoire-only workflows (ingest, pipeline, MCP, memory routing) need no Moltbook vars.

# -----------------------------------------------------------------------------
# Repertoire MCP server (dist/mcp/server.js)
# -----------------------------------------------------------------------------
# Overrides bundled package defaults (see src/paths.ts).
# Hardcoded today in .mcp.json repertoire server env block.

# CURATED_SIGNALS_PATH=/path/to/repertoire/data/curated_signals.json
# REPERTOIRE_DATA_DIR=/path/to/repertoire/data
# REPERTOIRE_STATE_PATH=/path/to/repertoire/data/inference-state.json
# REPERTOIRE_LOG_DIR=/path/to/repertoire/logs/groover-inference
# REPERTOIRE_FEEDBACK_DIR=/path/to/repertoire/logs/orchestrator-feedback

# -----------------------------------------------------------------------------
# 0xRay MCP governance (optional)
# -----------------------------------------------------------------------------
# Set on xray-governance MCP when forcing external governance path.
# XRAY_FORCE_MCP_GOVERNANCE=true