{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0xray.ai/schemas/features.schema.json",
  "title": "0xRay Features Configuration",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "memory_routing": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": {
          "type": "string",
          "enum": ["null", "repertoire", "custom"]
        },
        "module_path": { "type": "string" },
        "config": { "type": "object" }
      },
      "required": ["enabled", "provider"],
      "if": {
        "properties": {
          "enabled": { "const": true },
          "provider": { "enum": ["repertoire", "custom"] }
        }
      },
      "then": {
        "required": ["module_path"]
      }
    }
  },
  "additionalProperties": true
}